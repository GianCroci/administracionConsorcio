<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AdministracionConsorcios</title>
    <script type="importmap"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/indexConsorcio.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AdministracionConsorcios.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/jquery.dataTables.min.css">
</head>
<body class="flex flex-col min-h-screen">
    
    <div class="flex-1 flex flex-col">
        <main role="main" class="flex-1 flex flex-col">
            @RenderBody()
        </main>
    </div>

    <partial name="_Footer" />

    
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="~/js/indexConsorcio.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
